# Deploy script config. 複製為 .deploy.env 後填入實值。
# .deploy.env 已在 .gitignore，不會推到 GitHub。

# SSH 連線
SSH_KEY="/path/to/your-ssh-key.key"   # 含空白的路徑記得不要加引號 OR 整體用引號
SSH_HOST="ubuntu@1.2.3.4"             # user@host[:port]

# Server-side
DEPLOY_PATH="/www/wwwroot/imageanalysis.looptw.com"
NODE_BIN="/www/server/nodejs/v22.22.2/bin"    # aapanel Node.js bin dir

# PM2 process name (server 上的)
PM2_NAME="imageanalysis-web"

# Smoke test URL（部署完 health check）
SERVER_URL="https://imageanalysis.looptw.com"
