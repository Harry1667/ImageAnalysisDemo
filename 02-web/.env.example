# proxy-cli AI gateway
PROXY_BASE_URL=https://clip.twloop.com
PROXY_TOKEN=replace-me-with-real-bearer-token
PROXY_PROJECT=po-parser-demo

# Fallback chain: provider/model, comma-separated, tried in order.
# Any failure (auth / quota / provider_down / parse / schema validation)
# automatically falls through to the next. Each provider re-prompts once internally.
PROXY_CHAIN=gemini/gemini-2.5-flash,openai/gpt-5,gemini/gemini-2.5-pro
